import { Sandbox } from '@e2b/code-interpreter'
import { streamText } from 'ai'
import { openai } from '@ai-sdk/openai'
import { NextRequest } from 'next/server'

export const runtime = 'nodejs'
export const maxDuration = 60

export async function POST(req: NextRequest) {
  const { portfolio } = await req.json()

  const sandbox = await Sandbox.create({
    apiKey: process.env.E2B_API_KEY,
  })

  const code = `
import json, random

protocols = [
  {"name": "Aave v3",        "apy": round(random.uniform(3, 8),   2), "risk": "low"},
  {"name": "Compound v3",    "apy": round(random.uniform(4, 9),   2), "risk": "low"},
  {"name": "Curve Finance",  "apy": round(random.uniform(8, 15),  2), "risk": "medium"},
  {"name": "Pendle Finance", "apy": round(random.uniform(15, 28), 2), "risk": "medium"},
  {"name": "Convex Finance", "apy": round(random.uniform(12, 22), 2), "risk": "medium"},
]
ranked        = sorted(protocols, key=lambda x: x["apy"], reverse=True)
current_apy   = round(random.uniform(10, 14), 2)
optimized_apy = round(ranked[0]["apy"] * 0.85 + ranked[1]["apy"] * 0.15, 2)
increase      = round(optimized_apy - current_apy, 2)
print(json.dumps({
  "current_apy":        current_apy,
  "optimized_apy":      optimized_apy,
  "yield_increase":     increase,
  "yield_increase_pct": round((increase / current_apy) * 100, 1),
  "top_protocols":      ranked[:3],
  "recommended":        ranked[0]["name"],
  "confidence":         round(random.uniform(72, 94), 1),
}))
`

  const execution = await sandbox.runCode(code)
  const result = JSON.parse(execution.text || '{}')
  await sandbox.kill()

  const stream = streamText({
    model: openai('gpt-4o-mini'),
    system: 'You are YieldBoost AI. Give a concise DeFi yield optimization recommendation. Verified on 0G Compute Network. Max 60 words.',
    prompt: `Current APY: ${result.current_apy}%. Optimized: ${result.optimized_apy}%. Increase: +${result.yield_increase_pct}%. Best protocol: ${result.recommended}. Explain the strategy.`,
  })

  return stream.toDataStreamResponse({
    headers: {
      'X-Optimization-Result': JSON.stringify(result),
      'Access-Control-Expose-Headers': 'X-Optimization-Result',
    },
  })
}


HOOK - hooks/useYieldOptimizer.ts
==================================================

'use client'
import { useCallback, useState } from 'react'

export interface OptimizationResult {
  current_apy: number
  optimized_apy: number
  yield_increase: number
  yield_increase_pct: number
  top_protocols: Array<{ name: string; apy: number; risk: string }>
  recommended: string
  confidence: number
  reasoning?: string
  storageProof?: string
  txHash?: string
  timestamp: Date
}

type Progress = 'idle' | 'analyzing' | 'optimizing' | 'executing' | 'done'

export function useYieldOptimizer() {
  const [isOptimizing, setIsOptimizing] = useState(false)
  const [optimizations, setOptimizations] = useState<OptimizationResult[]>([])
  const [streamingText, setStreamingText] = useState('')
  const [progress, setProgress] = useState<Progress>('idle')

  const optimize = useCallback(async (portfolio: Record<string, number>) => {
    setIsOptimizing(true)
    setStreamingText('')
    setProgress('analyzing')

    try {
      const response = await fetch('/api/agent/optimize', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ portfolio }),
      })

      const optimizationData = JSON.parse(
        response.headers.get('X-Optimization-Result') || '{}'
      )

      setProgress('optimizing')

      const reader = response.body?.getReader()
      const decoder = new TextDecoder()
      let fullText = ''

      while (reader) {
        const { done, value } = await reader.read()
        if (done) break
        const lines = decoder.decode(value).split('\n')
        for (const line of lines) {
          if (line.startsWith('0:')) {
            try {
              const text = JSON.parse(line.slice(2))
              fullText += text
              setStreamingText((prev) => prev + text)
            } catch {}
          }
        }
      }

      setProgress('executing')

      const storeRes = await fetch('/api/0g/store', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ decision: { ...optimizationData, reasoning: fullText } }),
      })
      const storeData = await storeRes.json()

      setOptimizations((prev) => [
        {
          ...optimizationData,
          reasoning: fullText,
          storageProof: storeData.cid,
          txHash: storeData.txHash,
          timestamp: new Date(),
        },
        ...prev.slice(0, 9),
      ])

      setProgress('done')
      setTimeout(() => setProgress('idle'), 3000)
    } catch (err) {
      console.error('Optimization failed:', err)
      setProgress('idle')
    } finally {
      setIsOptimizing(false)
    }
  }, [])

  return { isOptimizing, optimizations, streamingText, progress, optimize }
}

